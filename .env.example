# Copy to .env and add your ElevenLabs key (for future fact voice generation)

ELEVENLABS_API_KEY=

VITE_ELEVENLABS_API_KEY=



# Default model for other scripts (SFX uses separate settings)

ELEVENLABS_MODEL=eleven_multilingual_v2

ELEVENLABS_SHAPES_MODEL=eleven_turbo_v2

ELEVENLABS_SHAPES_STABILITY=0.45

ELEVENLABS_SHAPES_SIMILARITY_BOOST=0.90

ELEVENLABS_SHAPES_STYLE=0.70

ELEVENLABS_SHAPES_USE_SPEAKER_BOOST=true



# Sound Effects API (scripts/elevenlabs-sfx-test.mjs) — same as ElevenLabs "Sound Effects" in the app

ELEVENLABS_SFX_DURATION=2

ELEVENLABS_SFX_PROMPT_INFLUENCE=0.55



# Fun-fact narration (scripts/elevenlabs-fact-voice-test.mjs, elevenlabs-fact-voice-batch.mjs)
# Full plain-English steps: data/FACT_VOICE_GUIDE.md
#
# In ElevenLabs → Voice Library: preview with a sample fact, Copy voice ID, paste below.
# Kid-friendly bubbly starting picks (public premade IDs — see data/FACT_VOICE_GUIDE.md):
#   Jessica (playful, bright):  cgSgspJ2msm6clMCkdW9
#   Gigi (cartoon kid):         jBpfuIE2acCO8z3wKNLl
#   Freya (energetic, hyped):   jsCqWAovK2LkecY7zXl4
# More presets: node scripts/list-fact-voice-presets.mjs
# If left blank, scripts use premade Adam (calm US male) — sounds the same every time until you set this.

ELEVENLABS_VOICE_ID=

# eleven_multilingual_v2: best for EN + Tagalog + Spanish (avoid eleven_turbo_v2 for TL/ES)

ELEVENLABS_FACT_MODEL=eleven_multilingual_v2

# Lower stability = more expression (0.25–0.35 kid-friendly). High stability sounds flat/monotone.

ELEVENLABS_FACT_STABILITY=0.30

ELEVENLABS_FACT_SIMILARITY_BOOST=0.78

# Style exaggerates narrator character (v2+ models); ~0.5–0.65 for premium story voice

ELEVENLABS_FACT_STYLE=0.55

# Slightly under 1.0 = calmer kid pacing (API range 0.25–4.0)

ELEVENLABS_FACT_SPEED=0.96

ELEVENLABS_FACT_USE_SPEAKER_BOOST=true



# Legacy aliases (optional; FACT_* takes precedence)

ELEVENLABS_STABILITY=0.30

ELEVENLABS_SIMILARITY_BOOST=0.78

ELEVENLABS_STYLE=0.55

ELEVENLABS_SPEED=0.96

ELEVENLABS_USE_SPEAKER_BOOST=true

